{
    "main": "dist/app.js",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "nest start --watch",
        "build": "tsc",
        "start": "node dist/app.js",
        "start:db": "sh ./scripts/startdb.sh",
        "stop:db": "sh ./scripts/stopdb.sh",
        "typeorm": "npm run build && npx typeorm -d dist/data-source.js",
        "migration:generate": "npm run typeorm -- migration:generate src/migrations/migration",
        "migration:run": "npm run typeorm -- migration:run",
        "migration:revet": "npm run typeorm -- migration:revert"
    },
    "dependencies": {
        "@fastify/helmet": "^13.0.2",
        "@fastify/static": "^9.1.3",
        "@nestjs/common": "^11.1.23",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.23",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/platform-fastify": "^11.1.23",
        "@nestjs/swagger": "^11.4.4",
        "@nestjs/typeorm": "^11.0.1",
        "bcryptjs": "^3.0.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "dotenv": "^17.4.2",
        "pg": "^8.21.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^1.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.21",
        "@types/bcryptjs": "^3.0.0",
        "typescript": "^6.0.3"
    }
}
