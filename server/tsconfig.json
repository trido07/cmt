{
    "compilerOptions": {
        "module": "commonjs",
        "esModuleInterop": true,
        "target": "es2020",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "skipLibCheck": true,
        "paths": {
            "*": ["./node_modules/*"]
        }
    },
    "include": ["src/**/*"]
}
